# ─────────────────────────────────────────────
# Supply Chain Intelligence — Environment Config
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# PostgreSQL / Supabase connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supply_chain
DB_USER=postgres
DB_PASSWORD=your_password_here

# Full connection string (alternative to above)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase (if using Supabase instead of local Postgres)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# API Keys (add as you integrate more sources)
# WORLD_BANK_API_KEY=   # not needed, public API
# FRED_API_KEY=your_fred_api_key_here

# Pipeline settings
LOG_LEVEL=INFO
PIPELINE_BATCH_SIZE=1000
